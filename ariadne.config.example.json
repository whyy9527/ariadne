{
  "_comment": "Copy to ariadne.config.json and edit. Paths are resolved relative to this file. Each repo declares zero or more scanners; a scanner is either a string (the type) or an object with `type` plus extra options.",
  "repos": [
    {
      "name": "gateway",
      "path": "../gateway",
      "scanners": ["graphql"]
    },
    {
      "name": "orders-svc",
      "path": "../orders-svc",
      "scanners": [
        "http",
        "kafka",
        {
          "type": "backend_clients",
          "client_target_map": {
            "billing": "billing-svc",
            "user": "user-svc"
          }
        }
      ]
    },
    {
      "name": "billing-svc",
      "path": "../billing-svc",
      "scanners": ["http", "kafka"]
    },
    {
      "name": "analytics",
      "path": "../analytics",
      "scanners": ["cube"]
    },
    {
      "name": "web",
      "path": "../web",
      "scanners": [
        "frontend_graphql",
        {
          "type": "frontend_rest",
          "base_class_service": {
            "OrdersApiService": "orders-svc",
            "BillingApiService": "billing-svc"
          }
        }
      ]
    },
    {
      "name": "bff",
      "path": "../bff",
      "scanners": [
        "graphql",
        {
          "type": "ts_http_outbound",
          "_comment": "Maps Apollo RESTDataSource settings keys and URL prefixes to target services. settings_key_map keys match the settings object property (e.g. settings.api.host → 'api'). url_prefix_map matches fetch/axios URL prefixes. client_name_map matches TypeScript client class name substrings.",
          "settings_key_map": {
            "api": "orders-svc",
            "billingService": "billing-svc",
            "userService": "user-svc"
          },
          "url_prefix_map": {
            "http://orders-svc": "orders-svc",
            "http://billing-svc": "billing-svc"
          },
          "client_name_map": {
            "OrdersClient": "orders-svc",
            "BillingClient": "billing-svc"
          }
        }
      ]
    }
  ]
}
